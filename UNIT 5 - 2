class Stack:
    def __init__(self):
        self.stack = []
      
    #Push Element onto Stack
    def push(self, item):
        self.stack.append(item)
      
    #Safe Pop Method
    def pop(self):
        if not self.is_empty():
            return self.stack.pop()
        else:
            return None

    def is_empty(self):
        return len(self.stack) == 0

    def size(self):
        return len(self.stack)

    #Display Stack
    def display(self):
      print("Stack:",self.stack)
